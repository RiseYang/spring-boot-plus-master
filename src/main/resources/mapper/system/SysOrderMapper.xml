<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="io.geekidea.boot.system.mapper.SysOrderMapper">

    <select id="getSysOrderById" resultType="io.geekidea.boot.system.vo.SysOrderVo">
        select *
        from sys_order
        where id = #{id}
    </select>

    <select id="getSysOrderPage" parameterType="io.geekidea.boot.system.query.SysOrderQuery"
            resultType="io.geekidea.boot.system.vo.SysOrderVo">
        select *
        from sys_order
        <where>
            <if test="keyword != null and keyword != ''">
                and (order_no like concat('%',#{keyword},'%')
                or customer_name like concat('%',#{keyword},'%')
                or phone like concat('%',#{keyword},'%'))
            </if>
            <if test="orderStatus != null">
                and order_status = #{orderStatus}
            </if>
        </where>
    </select>

</mapper>
